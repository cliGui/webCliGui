{
  "compilerOptions": {
    "outDir": "./dist/",
    "target": "esnext",
    "strict": true,
    "module": "esnext",
    "moduleResolution": "node",
    "isolatedModules": true,
    "resolveJsonModule": true,
    "jsx": "react",
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "typeRoots": [
      "node_modules/@types"
    ],
    "baseUrl": ".",
    "paths": {
      "@utils/*": ["src/utils/*"],
      "@components/*": ["src/components/*"],
      "@store/*": ["src/store/*"],
      "@icons/*": ["src/icons/*"],
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "index.d.ts"]
}
